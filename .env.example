APP_NAME=Enterprise Knowledge Ingestion
APP_ENV=development
LOG_LEVEL=INFO

CHUNK_SIZE_TOKENS=420
CHUNK_OVERLAP_TOKENS=60
MAX_PAGES_PER_SEGMENT=250
LARGE_DOCUMENT_PAGE_THRESHOLD=250
HARD_PAGE_SPLIT_THRESHOLD=2000
HARD_FILE_SPLIT_THRESHOLD_MB=500
USE_SEMANTIC_CHUNKING=false
ENABLE_LLM_BOUNDARY_STITCHING=true

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-layout

AZURE_CONTENT_UNDERSTANDING_ENDPOINT=
AZURE_CONTENT_UNDERSTANDING_KEY=
AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID=

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_QUERY_KEY=
AZURE_SEARCH_INDEX_NAME=enterprise-knowledge-index
AZURE_SEARCH_KNOWLEDGE_SOURCE_NAME=enterprise-knowledge-source
AZURE_SEARCH_KNOWLEDGE_BASE_NAME=enterprise-knowledge-base
AZURE_SEARCH_API_VERSION=2025-11-01-preview
AZURE_SEARCH_EXTRA_SOURCES_JSON=
AZURE_SEARCH_AUTO_BROADCAST_LIMIT=4

AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_FOUNDRY_RESOURCE_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_CHAT_DEPLOYMENT=
AZURE_FOUNDRY_PROJECT_ENDPOINT=
AZURE_FOUNDRY_AGENT_ID=
AZURE_SEARCH_LLM_DEPLOYMENT=
AZURE_SEARCH_LLM_MODEL_NAME=
AZURE_SEARCH_LLM_REASONING_EFFORT=low
AZURE_SEARCH_LLM_USE_MANAGED_IDENTITY=true
FOUNDRY_CHAT_MODE=search_knowledge_base

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=document-figure-artifacts
ENABLE_IMAGE_UNDERSTANDING=true
MAX_FIGURE_IMAGE_PIXELS=40000000
MAX_FIGURE_IMAGE_DIMENSION=4096

REQUEST_TIMEOUT_SECONDS=60
